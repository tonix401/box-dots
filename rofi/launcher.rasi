@import "~/.config/rofi/themes/matugen.rasi"

configuration {
    scroll-method:      1;
    show-icons:         true;
    sidebar-mode:       false;
    modi:               "drun";
    drun-display-format:"{name}";
}

* {
    font:               "JetBrainsMono Nerd Font 12";
}

window {
    padding:            0;
    border:             2px;
    border-radius:      12px;
    width:              580px;
    location:           center;
    anchor:             center;
    border-color:       @primary;
    background-color:   @background;
}

mainbox {
    spacing:            8px;
    padding:            10px;
    background-color:   transparent;
    children:           [ inputbar, listview ];
}

inputbar {
    spacing:            8px;
    border-radius:      8px;
    text-color:         @primary;
    children:           [ entry ];
    padding:            10px 14px;
    background-color:   transparent;
}

entry {
    vertical-align:     0.5;
    text-color:         @primary;
    background-color:   transparent;
    placeholder:        "Search apps...";
    placeholder-color:  @on-surface-variant;
}

listview {
    columns:            1;
    lines:              10;
    fixed-height:       true;
    scrollbar:          false;
    spacing:            2px;
    background-color:   transparent;
}

element {
    border-radius:      8px;
    spacing:            12px;
    padding:            9px 12px;
    orientation:        horizontal;
    background-color:   transparent;
    children:           [ element-icon, element-text ];
}

element-icon {
    vertical-align:     0.5;
    border-radius:      6px;
    padding:            4px;
    size:               1.4em;
    background-color:   transparent;
}

element-text {
    vertical-align:     0.5;
    expand:             true;
    text-color:         @primary;
    background-color:   transparent;
}

element-icon.selected {
    background-color:   @on-primary;
}

element.selected {
    background-color:   @primary;
}

element-text.selected {
    text-color:         @on-primary;
}
