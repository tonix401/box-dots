@import "~/.config/rofi/themes/matugen.rasi"

configuration {
    sidebar-mode:       false;
    show-icons:         false;
    scroll-method: 1;
}

* {
    font:               "JetBrainsMono Nerd Font 13";
}

window {
    width:              720px;
    location:           center;
    anchor:             center;
    background-color:   @background;
    border-color:       @primary;
    border-radius:      12px;
    border:             2px;
    padding:            0;
}

mainbox {
    background-color:   transparent;
    orientation:        horizontal;
    padding:            10px;
    spacing:            10px;
    children:           [ image, listview ];
}

image {
    background-color:   transparent;
    border-radius:      8px;
    background-image:   url("~/.cache/box-dots/current/wallpaper-square.png", width);
}

listview {
    columns:            1;
    scrollbar:          false;
    fixed-height:       false;
    spacing:            2px;
    background-color:   transparent;
}

element {
    padding:            12px 16px;
    border-radius:      8px;
    orientation:        horizontal;
    children:           [ element-text ];
    spacing:            0;
    background-color:   transparent;
}

element.selected {
    background-color:   @primary;
}

element-text {
    vertical-align:     0.5;
    expand:             true;
    background-color:   transparent;
    text-color:         @primary;
}

element-text.selected {
    text-color:         @on-primary;
}