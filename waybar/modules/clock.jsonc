{
  "group/clock-group": {
    "orientation": "horizontal",
    "modules": ["clock"]
  },

  "clock": {
    "timezone": "Europe/Berlin",
    "format": "  <span size='11pt'>{:%H:%M}</span>",
    "format-alt": "󰃱  <span size='11pt'>{:%Y/%m/%d}</span>",
    "tooltip-format": "<tt><small>{calendar}</small></tt>"
  }
}
