#!/usr/bin/env bash
set -euo pipefail

THEME="$HOME/.config/rofi/powermenu.rasi"

lock="箚뙻  Lock"
suspend="箚뮧  Suspend"
hibernate="箚쨪  Hibernate"
reboot="箚쐣  Reboot"
firmware="箚뜘  Firmware"
shutdown="箚맓  Shutdown"

chosen=$(printf '%s\n' "$lock" "$suspend" "$hibernate" "$reboot" "$firmware" "$shutdown" \
    | rofi -dmenu -p "Power" -theme "$THEME") || exit 0

case "$chosen" in
    "$lock")      loginctl lock-session ;;
    "$suspend")   systemctl suspend ;;
    "$hibernate") systemctl hibernate ;;
    "$reboot")    systemctl reboot ;;
    "$firmware")  systemctl reboot --firmware-setup ;;
    "$shutdown")  systemctl poweroff ;;
esac
