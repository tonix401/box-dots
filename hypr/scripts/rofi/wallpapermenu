#!/usr/bin/env bash
set -euo pipefail

WALLPAPER_DIR="$HOME/Pictures/Wallpapers"
WALLPAPER_THEME="$HOME/.config/rofi/wallpapermenu.rasi"
COLOR_THEME="$HOME/.config/rofi/colorpicker.rasi"

mapfile -d '' paths < <(find "$WALLPAPER_DIR" -maxdepth 3 \
    \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.gif" \) \
    -print0 | sort -z)

[ ${#paths[@]} -eq 0 ] && { notify-send "Wallpaper" "No images found in $WALLPAPER_DIR"; exit 1; }

THUMB_CACHE="$HOME/.cache/rofi-wallpapers"
mkdir -p "$THUMB_CACHE"

for path in "${paths[@]}"; do
    thumb="$THUMB_CACHE/$(md5sum <<< "$path" | cut -d' ' -f1).png"
    [ -f "$thumb" ] || magick "$path" -thumbnail 256x256^ -gravity center -extent 256x256 "$thumb"
done

# Step 1: pick wallpaper
gen_entries() {
    for path in "${paths[@]}"; do
        thumb="$THUMB_CACHE/$(md5sum <<< "$path" | cut -d' ' -f1).png"
        printf '%s\0icon\x1f%s\n' "$(basename "${path%.*}")" "$thumb"
    done
}

idx=$(gen_entries | rofi -dmenu -p "Wallpaper" -show-icons -theme "$WALLPAPER_THEME" -format i) || exit 0
IMAGE="${paths[$idx]}"

# Step 2: extract candidate source colors via matugen debug dry-run
debug_output=$(matugen image "$IMAGE" --debug --dry-run 2>&1 || true)

declare -a colors indices
while IFS= read -r line; do
    if [[ $line =~ \]\ ([0-9]+):\ (#[0-9a-fA-F]{6}) ]]; then
        indices+=("${BASH_REMATCH[1]}")
        colors+=("${BASH_REMATCH[2]}")
    fi
done <<< "$debug_output"

# If matugen found only one color it resolves automatically — skip the picker
if [ ${#colors[@]} -lt 2 ]; then
    "$HOME/.config/hypr/scripts/wallpaper" "$IMAGE"
    exit 0
fi

# Step 3: generate small color swatch PNGs and show in rofi
SWATCH_CACHE="$HOME/.cache/rofi-swatches"
mkdir -p "$SWATCH_CACHE"

for i in "${!colors[@]}"; do
    swatch="$SWATCH_CACHE/${colors[$i]#\#}.png"
    [ -f "$swatch" ] || magick -size 72x72 xc:"${colors[$i]}" "$swatch"
done

chosen=$(
    for i in "${!colors[@]}"; do
        printf '%s\0icon\x1f%s\n' "${colors[$i]}" "$SWATCH_CACHE/${colors[$i]#\#}.png"
    done \
    | rofi -dmenu -p "Source color" -show-icons -theme "$COLOR_THEME" -format i
) || exit 0

# Step 4: apply wallpaper with chosen source color index
"$HOME/.config/hypr/scripts/wallpaper" "$IMAGE" --source-color-index "${indices[$chosen]}"
